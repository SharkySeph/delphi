#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────
# Delphi launcher — bootstraps the environment and runs the CLI.
#
# Usage:
#   ./delphi                  Launch the REPL
#   ./delphi init my-song     Create a new project
#   ./delphi open ./my-song   Open a project in the REPL
#   ./delphi my-script.delphi Run a script
#   ./delphi --help           Show help
#
# This script will:
#   1. Locate (or create) a Python virtual environment
#   2. Install maturin if missing
#   3. Build the Rust engine if the .so is stale or missing
#   4. Hand off to the real `delphi` CLI entry point
# ─────────────────────────────────────────────────────────────
set -euo pipefail

# ── Resolve the Delphi source root (where this script lives) ─
DELPHI_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# ── Locate or create a virtual environment ───────────────────
find_venv() {
    # 1. Explicit override
    if [[ -n "${DELPHI_VENV:-}" ]] && [[ -d "$DELPHI_VENV" ]]; then
        echo "$DELPHI_VENV"
        return
    fi
    # 2. .venv in the source root
    if [[ -d "$DELPHI_ROOT/.venv" ]]; then
        echo "$DELPHI_ROOT/.venv"
        return
    fi
    # 3. venv in the source root
    if [[ -d "$DELPHI_ROOT/venv" ]]; then
        echo "$DELPHI_ROOT/venv"
        return
    fi
    # 4. Already inside an active venv
    if [[ -n "${VIRTUAL_ENV:-}" ]] && [[ -d "$VIRTUAL_ENV" ]]; then
        echo "$VIRTUAL_ENV"
        return
    fi
    # 5. None found — create one
    echo ""
}

VENV_DIR="$(find_venv)"

if [[ -z "$VENV_DIR" ]]; then
    echo "⚙  No virtual environment found. Creating .venv ..."
    python3 -m venv "$DELPHI_ROOT/.venv"
    VENV_DIR="$DELPHI_ROOT/.venv"
    echo "   Created $VENV_DIR"
fi

# Activate
# shellcheck disable=SC1091
source "$VENV_DIR/bin/activate"

# ── Ensure maturin + patchelf are installed ──────────────────
if ! command -v maturin &>/dev/null; then
    echo "⚙  Installing maturin ..."
    pip install --quiet "maturin[patchelf]"
elif ! command -v patchelf &>/dev/null; then
    pip install --quiet patchelf
fi

# ── Build the Rust engine if needed ──────────────────────────
ENGINE_SO="$(find "$VENV_DIR" -name '_engine*.so' 2>/dev/null | head -1 || true)"
CARGO_TOML="$DELPHI_ROOT/crates/delphi-py/Cargo.toml"

needs_build() {
    # No .so at all
    [[ -z "$ENGINE_SO" ]] && return 0
    # Source changed since last build
    if [[ -f "$CARGO_TOML" ]] && [[ "$CARGO_TOML" -nt "$ENGINE_SO" ]]; then
        return 0
    fi
    # Any Rust source newer than the .so
    local newest_rs
    newest_rs="$(find "$DELPHI_ROOT/crates" -name '*.rs' -newer "$ENGINE_SO" 2>/dev/null | head -1 || true)"
    [[ -n "$newest_rs" ]] && return 0
    # Any Python source newer than the .so
    local newest_py
    newest_py="$(find "$DELPHI_ROOT/python" -name '*.py' -newer "$ENGINE_SO" 2>/dev/null | head -1 || true)"
    [[ -n "$newest_py" ]] && return 0
    return 1
}

if needs_build; then
    echo "⚙  Building Delphi engine ..."
    (cd "$DELPHI_ROOT" && maturin develop --quiet 2>&1 | grep -v '^$')
    echo "   Build complete."
fi

# ── Ensure prompt_toolkit is installed (needed for REPL) ─────
python -c "import prompt_toolkit" 2>/dev/null || {
    echo "⚙  Installing prompt_toolkit ..."
    pip install --quiet prompt_toolkit
}

# ── Hand off to the Delphi CLI ───────────────────────────────
# Clear the screen so the REPL starts fresh (only for interactive use)
if [[ -t 1 ]] && [[ $# -eq 0 || "$1" == "open" ]]; then
    clear
fi
exec python -m delphi.cli "$@"
